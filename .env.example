# Core services
SUPABASE_URL=https://tvupqsxaufbcmeobvhqj.supabase.co
SUPABASE_KEY=replace-with-your-supabase-service-role-key
GOOGLE_API_KEY=replace-with-your-google-api-key

# Choose one provider: groq | openrouter | neokens | ollama
LLM_PROVIDER=neokens

# Groq
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_HELPER_MODEL=llama-3.1-8b-instant

# OpenRouter
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_HELPER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://serva-s.com
OPENROUTER_APP_NAME=Serva-S RAG Assistant

# Neokens
NEOKENS_API_KEY=replace-with-your-neokens-api-key
NEOKENS_BASE_URL=https://api.neokens.com/v1
NEOKENS_MODEL=gemini-3.1-pro-low
NEOKENS_HELPER_MODEL=gemini-3.1-pro-low
NEOKENS_REQUEST_TIMEOUT=120

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HELPER_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=8192
OLLAMA_REQUEST_TIMEOUT=120

# Local runtime
REQUEST_TIMEOUT=30
GRADIO_SHARE=false
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
EVAL_USE_JUDGE=false

# Keep these false unless you intentionally want to rebuild matching embeddings.
RESET_SERVICE_DOCUMENTS=false
RESET_POLICY_DOCUMENTS=false
RESET_SCENARIO_DOCUMENTS=false
